# MongoDB Atlas connection string
# Example: mongodb+srv://user:password@cluster0.xxxx.mongodb.net/8waves?retryWrites=true&w=majority
MONGODB_URI=

# Secret used to sign the admin session token. Use a long random string.
JWT_SECRET=

# Admin login credentials (used once by the seed script to create the admin account)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
